{
  "id": "jjdevhub",
  "realm": "jjdevhub",
  "enabled": true,
  "roles": {
    "realm": [
      { "name": "Student", "description": "Public read access" },
      { "name": "Owner", "description": "Full write access" }
    ]
  },
  "clients": [
    {
      "clientId": "jjdevhub-web",
      "name": "jjdevhub-web",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": ["http://localhost:8081/*", "http://localhost:4200/*", "http://127.0.0.1:8081/*"],
      "webOrigins": ["+"]
    },
    {
      "clientId": "jjdevhub-api",
      "name": "jjdevhub-api",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "jjdevhub-api-dev-secret",
      "serviceAccountsEnabled": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": false
    }
  ]
}
