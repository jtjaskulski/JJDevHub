# JJDevHub — production environment template
# Copy to .env and fill in real values BEFORE deploying.
# NEVER commit .env to git — only this .example file.

# ── Domain ───────────────────────────────────────────────────────
DOMAIN=jjdevhub.pl

# ── PostgreSQL ───────────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_strong_password_here

# ── Keycloak admin ───────────────────────────────────────────────
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=CHANGE_ME_keycloak_admin

# ── Keycloak client secret (jjdevhub-api confidential client) ───
KEYCLOAK_CLIENT_SECRET=CHANGE_ME_api_client_secret

# ── Vault ────────────────────────────────────────────────────────
VAULT_ENABLED=false
VAULT_TOKEN=

# ── Grafana ──────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_grafana

# ── SSL certificates (absolute path on host) ────────────────────
# Directory containing origin.pem and origin-key.pem from Cloudflare
SSL_CERT_DIR=/etc/ssl/cloudflare
