{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "HTTP Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(http_server_request_duration_seconds_count{service=\"content-api\"}[5m])",
          "legendFormat": "{{http_request_method}} {{url_scheme}}://{{url_template}} [{{http_response_status_code}}]"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "title": "HTTP Request Duration (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_server_request_duration_seconds_bucket{service=\"content-api\"}[5m]))",
          "legendFormat": "p95 {{http_request_method}} {{url_template}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Active HTTP Connections",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "http_server_active_requests{service=\"content-api\"}"
        }
      ]
    },
    {
      "title": "Error Rate (5xx)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_server_request_duration_seconds_count{service=\"content-api\",http_response_status_code=~\"5..\"}[5m]))"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 0.1 }] } }
      }
    },
    {
      "title": "Process Memory (MB)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "process_working_set_bytes{service=\"content-api\"} / 1024 / 1024",
          "legendFormat": "Working Set"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "decmbytes" }
      }
    },
    {
      "title": "GC Collections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "rate(dotnet_gc_collections_total{service=\"content-api\"}[5m])",
          "legendFormat": "Gen {{dotnet_gc_heap_generation}}"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["jjdevhub", "content-api", "dotnet"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "JJDevHub Content API",
  "uid": "jjdevhub-content-api"
}
