{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "ContentDb": "Host=localhost;Port=5433;Database=jjdevhub_content;Username=postgres;Password=password"
  },
  "MongoDb": {
    "ConnectionString": "mongodb://localhost:27018",
    "DatabaseName": "jjdevhub_content_read"
  },
  "Kafka": {
    "BootstrapServers": "localhost:29092"
  },
  "Outbox": {
    "PublisherEnabled": true,
    "PollIntervalMs": 1000,
    "BatchSize": 50,
    "ErrorBackoffMs": 5000
  },
  "Vault": {
    "Enabled": false,
    "Address": "http://localhost:8201",
    "Token": "jjdevhub-root-token"
  },
  "Keycloak": {
    "realm": "jjdevhub",
    "auth-server-url": "",
    "ssl-required": "none",
    "resource": "jjdevhub-api",
    "verify-token-audience": false,
    "credentials": {
      "secret": "jjdevhub-api-dev-secret"
    }
  }
}
